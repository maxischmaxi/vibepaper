CompileFlags:
  Add:
    - -xc
    - -std=gnu11
    - -D_GNU_SOURCE
    # Build all backends in the IDE so their bodies are analyzed (the .c files
    # are wrapped in #ifdef BG_BACKEND_*); the Makefile gates them per build.
    - -DBG_BACKEND_WLR
    - -DBG_BACKEND_X11
    - -DBG_BACKEND_GNOME
    - -DBG_BACKEND_KDE
    - -Isrc
    - -Iprotocols
    - -Ithird_party
    - -I/usr/include/cjson
    # gnome backend (GSettings) and kde backend (libdbus) headers
    - -I/usr/include/glib-2.0
    - -I/usr/lib/glib-2.0/include
    - -I/usr/include/dbus-1.0
    - -I/usr/lib/dbus-1.0/include
