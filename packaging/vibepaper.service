[Unit]
Description=vibepaper Wayland wallpaper daemon
Documentation=https://github.com/maxischmaxi/vibepaper
PartOf=graphical-session.target
After=graphical-session.target
# Only start inside a Wayland session (the daemon needs WAYLAND_DISPLAY).
ConditionEnvironment=WAYLAND_DISPLAY

[Service]
Type=simple
ExecStart=/usr/bin/vibepaper daemon
Restart=on-failure
RestartSec=2

[Install]
WantedBy=graphical-session.target
