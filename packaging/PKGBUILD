# Maintainer: maxischmaxi <max@jeschek.dev>
#
# Builds the latest main branch from GitHub. For a stable, versioned package
# create git tags (e.g. v0.1.0) and switch `source` to the release tarball.

pkgname=vibepaper-git
_pkgname=vibepaper
pkgver=0.1.0.r6.g53176d9   # placeholder; pkgver() recomputes from git at build time
pkgrel=1
pkgdesc="Wayland wallpaper daemon that generates and refines wallpapers via OpenAI, Gemini, Stability and other image APIs"
arch=('x86_64')
url="https://github.com/maxischmaxi/vibepaper"
license=('MIT')
# wayland+wayland-protocols → wlr backend; libxcb → x11 backend;
# glib2 → gnome backend (GSettings); dbus → kde backend. Build all four by
# default (Makefile BACKENDS); the daemon picks one at runtime.
depends=('wayland' 'curl' 'cjson' 'libxcb' 'glib2' 'dbus')
makedepends=('git' 'wayland-protocols' 'pkgconf')
provides=("$_pkgname")
conflicts=("$_pkgname")
source=("$_pkgname::git+https://github.com/maxischmaxi/vibepaper.git")
sha256sums=('SKIP')

pkgver() {
	cd "$srcdir/$_pkgname"
	# 0.1.0.r<commits>.g<short-hash> — sortable and unique per commit.
	printf '0.1.0.r%s.g%s' \
		"$(git rev-list --count HEAD)" \
		"$(git rev-parse --short HEAD)"
}

build() {
	cd "$srcdir/$_pkgname"
	make
}

package() {
	cd "$srcdir/$_pkgname"
	# PREFIX=/usr → /usr/bin/vibepaper; DESTDIR stages into the package root.
	make PREFIX=/usr DESTDIR="$pkgdir" install

	# Optional systemd user service for non-Hyprland Wayland sessions
	# (sway, river, …). Enable with: systemctl --user enable --now vibepaper
	install -Dm644 packaging/vibepaper.service \
		"$pkgdir/usr/lib/systemd/user/vibepaper.service"

	install -Dm644 README.md "$pkgdir/usr/share/doc/$_pkgname/README.md"

	if [ -f LICENSE ]; then
		install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$_pkgname/LICENSE"
	fi
}
